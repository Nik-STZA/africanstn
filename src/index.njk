---
layout: base.njk
pageTitle: Home
navActive: home
---

<section class="hero circuit-bg section--circuit" aria-labelledby="hero-title" style="position:relative;">
  <div class="hero-inner">
    <div style="margin:0 auto 40px;text-align:center;">
      <img src="/assets/images/africanstn-logo-white.svg"
           alt="{{ site.site_name }}"
           style="max-width:320px;width:100%;height:auto;display:block;margin:0 auto;">
    </div>
    <h1 class="hero-title" id="hero-title">{{ home.hero_headline }}</h1>
    <p class="hero-sub">{{ home.hero_subheadline }}</p>
    <div class="hero-actions">
      <a href="/join/" class="btn btn-primary">{{ home.hero_cta_primary }}</a>
      <a href="/services/" class="btn btn-outline">{{ home.hero_cta_secondary }}</a>
    </div>
  </div>
</section>

<section class="section section--white">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="eyebrow">What we do</span>
      <h2 class="section-title">{{ home.what_we_do_heading }}</h2>
      <div class="section-divider section-divider--center"></div>
    </div>
    <div class="grid-3">
      <div class="card card--gold-top reveal">
        <div class="card-icon" aria-hidden="true"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C5A059" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
        <h3>{{ home.card1_title }}</h3>
        <p>{{ home.card1_body }}</p>
        <a href="/services/" class="card-link">Learn more →</a>
      </div>
      <div class="card card--gold-top reveal">
        <div class="card-icon" aria-hidden="true"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C5A059" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
        <h3>{{ home.card2_title }}</h3>
        <p>{{ home.card2_body }}</p>
        <a href="/services/" class="card-link">Learn more →</a>
      </div>
      <div class="card card--gold-top reveal">
        <div class="card-icon" aria-hidden="true"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C5A059" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
        <h3>{{ home.card3_title }}</h3>
        <p>{{ home.card3_body }}</p>
        <a href="/ecosystem/" class="card-link">Learn more →</a>
      </div>
    </div>
  </div>
</section>

<section class="section section--warm">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Services</span>
      <h2 class="section-title">{{ home.services_preview_heading }}</h2>
      <div class="section-divider"></div>
    </div>
    <div class="grid-2">
      <div class="card card--gold-top reveal">
        <h3>{{ home.services_card1_title }}</h3>
        <p>{{ home.services_card1_body }}</p>
        <a href="/services/" class="card-link">Find out more →</a>
      </div>
      <div class="card card--gold-top reveal">
        <h3>{{ home.services_card2_title }}</h3>
        <p>{{ home.services_card2_body }}</p>
        <a href="/join/" class="card-link">Register interest →</a>
      </div>
    </div>
  </div>
</section>

<section class="section circuit-bg section--circuit" style="position:relative;">
  <div class="container" style="text-align:center;">
    <div class="reveal">
      <span class="eyebrow">Get involved</span>
      <h2 class="section-title section-title--white" style="max-width:600px;margin:0 auto 16px;">{{ home.cta_heading }}</h2>
      <p class="section-lead section-lead--dark" style="margin:0 auto 36px;max-width:580px;">{{ home.cta_body }}</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <a href="/join/" class="btn btn-primary">Register interest</a>
        <a href="/about/" class="btn btn-outline">About AfricanSTN</a>
      </div>
    </div>
  </div>
</section>
