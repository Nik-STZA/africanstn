---
layout: base.njk
navActive: what
pagination:
  data: languages.list
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}/what-is-sports-tech/index.html{% else %}/{{ lang }}/what-is-sports-tech/index.html{% endif %}"
---
{% set t = i18n[lang] %}
{% set langPrefix = "" if lang == "en" else "/" + lang %}

<section class="circuit-bg page-hero" aria-labelledby="page-title">
  <div class="container">
    <div class="hero-inner" style="min-height:unset;padding:40px 0 32px;">
      <span class="eyebrow">{{ t.what.hero_eyebrow }}</span>
      <h1 class="hero-title" id="page-title" style="font-size:clamp(28px,4.5vw,50px);">{{ t.what.hero_heading }}</h1>
      <p class="hero-sub">{{ t.what.hero_sub }}</p>
      <p class="hero-note">{{ t.what.hero_note }}</p>
      <div class="hero-actions">
        <a href="#how-structured" class="btn btn-primary">{{ t.what.see_structure_btn }}</a>
        <a href="{{ langPrefix }}/ecosystem/" class="btn btn-outline">{{ t.what.african_ecosystem_btn }}</a>
      </div>
    </div>
  </div>
</section>

<!-- Definition -->
<section class="section section--white" aria-labelledby="definition-title">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">{{ t.what.definition_eyebrow }}</span>
      <h2 class="section-title" id="definition-title">{{ t.what.definition_heading }}</h2>
      <div class="section-divider"></div>
      <p class="section-lead">{{ t.what.definition_lead }}</p>
    </div>
    <div class="grid-3">
      <div class="card card--gold-top reveal">
        <h3>{{ t.what.perf_title }}</h3>
        <p>{{ t.what.perf_body }}</p>
      </div>
      <div class="card card--gold-top reveal">
        <h3>{{ t.what.biz_title }}</h3>
        <p>{{ t.what.biz_body }}</p>
      </div>
      <div class="card card--gold-top reveal">
        <h3>{{ t.what.infra_title }}</h3>
        <p>{{ t.what.infra_body }}</p>
      </div>
    </div>
  </div>
</section>

<!-- Market structure -->
<section class="section section--warm" id="how-structured" aria-labelledby="structure-title">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="eyebrow">{{ t.what.structure_eyebrow }}</span>
      <h2 class="section-title" id="structure-title">{{ t.what.structure_heading }}</h2>
      <div class="section-divider section-divider--center"></div>
      <p class="section-lead" style="margin:0 auto 40px;">{{ t.what.structure_lead }}</p>
    </div>
    <div class="infographic reveal">
      <div class="zone zone--outer">
        <div class="zone-title">{{ t.what.elite_title }}</div>
        <p style="font-size:12px;color:rgba(255,255,255,0.45);">{{ t.what.elite_body }}</p>
      </div>
      <div class="grid-2" style="margin-bottom:12px;">
        <div class="zone zone--gold">
          <div class="zone-title">{{ t.what.biz_zone_title }}</div>
          {% for item in t.what.biz_zone_items | splitList %}
            <div class="vertical-item">{{ item }}</div>
          {% endfor %}
        </div>
        <div class="zone zone--gold">
          <div class="zone-title">{{ t.what.mass_zone_title }}</div>
          {% for item in t.what.mass_zone_items | splitList %}
            <div class="vertical-item">{{ item }}</div>
          {% endfor %}
        </div>
      </div>
      <div class="zone zone--gold" style="text-align:center;">
        <div class="zone-title" style="text-align:center;border:none;margin-bottom:10px;">{{ t.what.athlete_zone_title }}</div>
        <div style="display:flex;justify-content:center;flex-wrap:wrap;gap:4px;">
          {% for chip in t.what.athlete_chips | splitList %}
            <span class="chip">{{ chip }}</span>
          {% endfor %}
        </div>
      </div>
      <div class="infographic-attr">{{ t.what.infographic_attr1 }}</div>
    </div>
  </div>
</section>

<!-- Technology domains -->
<section class="section section--dark" aria-labelledby="domains-title">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="eyebrow">{{ t.what.domains_eyebrow }}</span>
      <h2 class="section-title section-title--white" id="domains-title">{{ t.what.domains_heading }}</h2>
      <div class="section-divider section-divider--center"></div>
      <p class="section-lead section-lead--dark" style="margin:0 auto 40px;">{{ t.what.domains_lead }}</p>
    </div>
    <div class="infographic reveal" style="background:#0D0F11;">
      <div class="infographic-title">{{ t.what.domains_title }} · <span>AfricanSTN</span></div>
      <div class="grid-2">
        <div class="zone zone--gold">
          <div class="zone-title">{{ t.what.ict_title }}</div>
          <div class="chip-list">
            {% for chip in t.what.ict_chips | splitList %}<span class="chip">{{ chip }}</span>{% endfor %}
          </div>
        </div>
        <div class="zone zone--green">
          <div class="zone-title">{{ t.what.med_title }}</div>
          <div class="chip-list">
            {% for chip in t.what.med_chips | splitList %}<span class="chip">{{ chip }}</span>{% endfor %}
          </div>
        </div>
        <div class="zone zone--grey">
          <div class="zone-title">{{ t.what.mat_title }}</div>
          <div class="chip-list">
            {% for chip in t.what.mat_chips | splitList %}<span class="chip">{{ chip }}</span>{% endfor %}
          </div>
        </div>
        <div class="zone zone--amber">
          <div class="zone-title">{{ t.what.sens_title }}</div>
          <div class="chip-list">
            {% for chip in t.what.sens_chips | splitList %}<span class="chip">{{ chip }}</span>{% endfor %}
          </div>
        </div>
      </div>
      <div class="infographic-attr">{{ t.what.infographic_attr2 }}</div>
    </div>
  </div>
</section>

<!-- Africa context -->
<section class="section section--white" aria-labelledby="africa-title">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="eyebrow">{{ t.what.africa_eyebrow }}</span>
      <h2 class="section-title" id="africa-title">{{ t.what.africa_heading }}</h2>
      <div class="section-divider section-divider--center"></div>
      <p class="section-lead" style="margin:0 auto;">{{ t.what.africa_lead }}</p>
    </div>
    <div class="grid-2 reveal" style="gap:32px;align-items:start;">
      <div>
        <div class="card card--gold-top">
          <h3>{{ t.what.africa_card1_title }}</h3>
          <p>{{ t.what.africa_card1_body }}</p>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="card card--gold-top" style="padding:20px;">
          <h3 style="font-size:15px;">{{ t.what.africa_card2_title }}</h3>
          <p>{{ t.what.africa_card2_body }}</p>
        </div>
        <div class="card card--gold-top" style="padding:20px;">
          <h3 style="font-size:15px;">{{ t.what.africa_card3_title }}</h3>
          <p>{{ t.what.africa_card3_body }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Where AfricanSTN fits -->
<section class="section section--warm" aria-labelledby="role-title">
  <div class="container">
    <div class="text-visual reveal">
      <div>
        <span class="eyebrow">{{ t.what.role_eyebrow }}</span>
        <h2 class="section-title" id="role-title">{{ t.what.role_heading }}</h2>
        <div class="section-divider"></div>
        <p style="font-size:15px;color:var(--text-secondary);line-height:1.8;margin-bottom:24px;">{{ t.what.role_body }}</p>
        <a href="{{ langPrefix }}/join/" class="btn btn-primary" style="margin-right:12px;">{{ t.what.role_get_involved }}</a>
        <a href="{{ langPrefix }}/services/" class="btn btn-outline-gold">{{ t.what.role_services }}</a>
      </div>
      <div class="grid-2" style="gap:16px;align-self:center;">
        <div class="card card--gold-top" style="padding:20px;">
          <h3 style="font-size:15px;">{{ t.what.role_card1_title }}</h3>
          <p>{{ t.what.role_card1_body }}</p>
        </div>
        <div class="card card--gold-top" style="padding:20px;">
          <h3 style="font-size:15px;">{{ t.what.role_card2_title }}</h3>
          <p>{{ t.what.role_card2_body }}</p>
        </div>
        <div class="card card--gold-top" style="padding:20px;grid-column:1/-1;">
          <h3 style="font-size:15px;">{{ t.what.role_card3_title }}</h3>
          <p>{{ t.what.role_card3_body }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section circuit-bg--subtle">
  <div class="container" style="text-align:center;">
    <div class="reveal">
      <span class="eyebrow">{{ t.what.cta_eyebrow }}</span>
      <h2 class="section-title section-title--white" style="max-width:580px;margin:0 auto 16px;">{{ t.what.cta_heading }}</h2>
      <p class="section-lead section-lead--dark" style="margin:0 auto 36px;max-width:560px;">{{ t.what.cta_body }}</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <a href="{{ langPrefix }}/ecosystem/" class="btn btn-primary">{{ t.what.ecosystem_btn }}</a>
        <a href="{{ langPrefix }}/join/" class="btn btn-outline">{{ t.what.register_btn }}</a>
      </div>
    </div>
  </div>
</section>
