---
layout: base.njk
navActive: contact
pagination:
  data: languages.list
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}/contact/index.html{% else %}/{{ lang }}/contact/index.html{% endif %}"
---
{% set t = i18n[lang] %}
{% set langPrefix = "" if lang == "en" else "/" + lang %}

<section class="circuit-bg--subtle page-hero" aria-labelledby="page-title">
  <div class="container">
    <div class="hero-inner" style="min-height:unset;padding:40px 0 32px;">
      <span class="eyebrow">{{ t.contact.hero_eyebrow }}</span>
      <h1 class="hero-title" id="page-title" style="font-size:clamp(28px,4.5vw,48px);">{{ t.contact.hero_heading }}</h1>
      <p class="hero-sub" style="font-size:17px;">{{ t.contact.hero_subheading }}</p>
    </div>
  </div>
</section>

<section class="section section--dark" aria-label="{{ t.contact.details_heading }}">
  <div class="container">
    <div class="grid-2 reveal" style="gap:48px;align-items:start;">
      <div>
        <span class="eyebrow">{{ t.contact.details_eyebrow }}</span>
        <h2 class="section-title section-title--white" style="font-size:26px;margin-bottom:32px;">{{ t.contact.details_heading }}</h2>

        <div class="contact-detail">
          <div class="contact-detail-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C5A059" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <div>
            <div class="contact-detail-label">{{ t.contact.label_website }}</div>
            <div class="contact-detail-value"><a href="https://africanstn.com">africanstn.com</a></div>
          </div>
        </div>

        <div class="contact-detail">
          <div class="contact-detail-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C5A059" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,4 12,13 2,4"/></svg>
          </div>
          <div>
            <div class="contact-detail-label">{{ t.contact.label_email }}</div>
            <div class="contact-detail-value"><a href="mailto:hello@stza.io">hello@stza.io</a></div>
          </div>
        </div>

        <div class="contact-detail">
          <div class="contact-detail-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C5A059" stroke-width="1.8" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="contact-detail-label">{{ t.contact.label_sa_entity }}</div>
            <div class="contact-detail-value">
              {{ t.contact.sa_entity_value }}<br>
              <span style="font-size:12px;color:rgba(255,255,255,0.4);">{{ t.contact.sa_entity_meta }}</span>
            </div>
          </div>
        </div>

        <div class="contact-detail">
          <div class="contact-detail-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C5A059" stroke-width="1.8" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>