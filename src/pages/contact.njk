<section class="section section--warm" aria-labelledby="form-title">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="eyebrow">Send a message</span>
      <h2 class="section-title" id="form-title">Contact form</h2>
      <div class="section-divider section-divider--center"></div>
      <p class="section-lead" style="margin:0 auto 40px;">Complete the form below and the team will respond within two business days.</p>
    </div>
    <div class="form-wrap" style="padding:32px;">
      <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/contact/">
        <input type="hidden" name="form-name" value="contact" />
        <p style="display:none;">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>
        <div class="form-grid">
          <div class="form-field">
            <label for="contact-name" class="form-label">Name <span aria-hidden="true">*</span></label>
            <input type="text" id="contact-name" name="name" required class="form-input" placeholder="Your full name" />
          </div>
          <div class="form-field">
            <label for="contact-email" class="form-label">Email <span aria-hidden="true">*</span></label>
            <input type="email" id="contact-email" name="email" required class="form-input" placeholder="you@example.com" />
          </div>
          <div class="form-field">
            <label for="contact-org" class="form-label">Organisation</label>
            <input type="text" id="contact-org" name="organisation" class="form-input" placeholder="Your company or organisation" />
          </div>
          <div class="form-field">
            <label for="contact-type" class="form-label">Enquiry type <span aria-hidden="true">*</span></label>
            <select id="contact-type" name="enquiry-type" required class="form-input">
              <option value="" disabled selected>Select an option</option>
              <option value="POPIA representation">POPIA representation</option>
              <option value="Directory & market intelligence">Directory &amp; market intelligence</option>
              <option value="Partnership & commercial">Partnership &amp; commercial</option>
              <option value="General enquiry">General enquiry</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="form-field form-field--full">
            <label for="contact-message" class="form-label">Message <span aria-hidden="true">*</span></label>
            <textarea id="contact-message" name="message" required class="form-input" rows="5" placeholder="How can we help?"></textarea>
          </div>
        </div>
        <div style="text-align:center;margin-top:24px;">
          <button type="submit" class="btn btn-primary">Send message</button>
        </div>
        <p style="text-align:center;font-size:12px;color:var(--text-muted);margin-top:16px;">Your details are used solely to respond to your enquiry. See our <a href="/privacy/">privacy policy</a>.</p>
      </form>
    </div>
  </div>
</section>