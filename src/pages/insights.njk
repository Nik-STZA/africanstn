---
layout: base.njk
navActive: insights
pagination:
  data: languages.list
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}/insights/index.html{% else %}/{{ lang }}/insights/index.html{% endif %}"
---
{% set t = i18n[lang] %}
{% set langPrefix = "" if lang == "en" else "/" + lang %}

<section class="circuit-bg--subtle page-hero" aria-labelledby="page-title">
  <div class="container">
    <div class="hero-inner" style="min-height:unset;padding:40px 0 32px;">
      <span class="eyebrow">{{ t.insights.hero_eyebrow }}</span>
      <h1 class="hero-title" id="page-title" style="font-size:clamp(28px,4.5vw,48px);">{{ t.insights.hero_heading }}</h1>
      <p class="hero-sub" style="font-size:17px;">{{ t.insights.hero_subheading }}</p>
    </div>
  </div>
</section>

{# ── NEWS ── #}
<section class="section section--warm" aria-labelledby="news-heading">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">{{ t.insights.news_eyebrow }}</span>
      <h2 class="section-title" id="news-heading">{{ t.insights.news_heading }}</h2>
      <div class="section-divider"></div>

      {% set newsItems = [] %}
      {% for post in posts %}
        {% if post.category == "News" %}
          {% set newsItems = (newsItems.push(post), newsItems) %}
        {% endif %}
      {% endfor %}

      {% if newsItems.length > 0 %}
        <div class="grid-2" style="gap:24px;margin-top:32px;">
          {% for post in newsItems %}
            {% set loc = post.i18n[lang] or {} %}
            <article class="card card--gold-top" style="padding:24px;">
              <p style="font-size:12px;color:var(--text-muted);margin-bottom:8px;">{{ post.date }}</p>
              <h3 style="font-size:16px;margin-bottom:10px;">{{ loc.title or post.title }}</h3>
              <p>{{ loc.excerpt or post.excerpt }}</p>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p style="color:var(--text-muted);font-size:15px;margin-top:16px;">{{ t.insights.news_empty }}</p>
      {% endif %}
    </div>
  </div>
</section>

{# ── INDUSTRY REPORTS ── #}
<section class="section section--white" id="reports" aria-labelledby="reports-heading">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">{{ t.insights.reports_eyebrow }}</span>
      <h2 class="section-title" id="reports-heading">{{ t.insights.reports_heading }}</h2>
      <div class="section-divider"></div>

      {% set reportItems = [] %}
      {% for post in posts %}
        {% if post.category == "Industry report" %}
          {% set reportItems = (reportItems.push(post), reportItems) %}
        {% endif %}
      {% endfor %}

      {% if reportItems.length > 0 %}
        <div class="grid-2" style="gap:24px;margin-top:32px;">
          {% for post in reportItems %}
            {% set loc = post.i18n[lang] or {} %}
            <article class="card card--gold-top" style="padding:24px;">
              <p style="font-size:12px;color:var(--text-muted);margin-bottom:8px;">{{ post.date }}</p>
              <h3 style="font-size:16px;margin-bottom:10px;">{{ loc.title or post.title }}</h3>
              <p>{{ loc.excerpt or post.excerpt }}</p>
              {% if post.download %}
                <a href="{{ post.download }}" download target="_blank" rel="noopener" style="display:inline-block;margin-top:12px;font-size:14px;font-weight:600;color:var(--accent-gold);">{{ t.insights.download_report }}</a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p style="color:var(--text-muted);font-size:15px;margin-top:16px;">{{ t.insights.reports_empty }}</p>
      {% endif %}
    </div>
  </div>
</section>

{# ── CASE STUDIES ── #}
<section class="section section--warm" aria-labelledby="cases-heading">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">{{ t.insights.cases_eyebrow }}</span>
      <h2 class="section-title" id="cases-heading">{{ t.insights.cases_heading }}</h2>
      <div class="section-divider"></div>

      {% set caseItems = [] %}
      {% for post in posts %}
        {% if post.category == "Case study" %}
          {% set caseItems = (caseItems.push(post), caseItems) %}
        {% endif %}
      {% endfor %}

      {% if caseItems.length > 0 %}
        <div class="grid-2" style="gap:24px;margin-top:32px;">
          {% for post in caseItems %}
            {% set loc = post.i18n[lang] or {} %}
            <article class="card card--gold-top" style="padding:24px;">
              <p style="font-size:12px;color:var(--text-muted);margin-bottom:8px;">{{ post.date }}</p>
              <h3 style="font-size:16px;margin-bottom:10px;">{{ loc.title or post.title }}</h3>
              <p>{{ loc.excerpt or post.excerpt }}</p>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p style="color:var(--text-muted);font-size:15px;margin-top:16px;">{{ t.insights.cases_empty }}</p>
      {% endif %}
    </div>
  </div>
</section>

{# ── CTA ── #}
<section class="section circuit-bg section--circuit">
  <div class="container" style="text-align:center;">
    <div class="reveal">
      <span class="eyebrow">{{ t.insights.cta_eyebrow }}</span>
      <h2 class="section-title section-title--white" style="max-width:560px;margin:0 auto 16px;">{{ t.insights.cta_heading }}</h2>
      <p class="section-lead section-lead--dark" style="margin:0 auto 36px;max-width:540px;">{{ t.insights.cta_body }}</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <a href="{{ langPrefix }}/join/" class="btn btn-primary">{{ t.insights.register_interest }}</a>
        <a href="{{ langPrefix }}/contact/" class="btn btn-outline">{{ t.insights.contact_us }}</a>
      </div>
    </div>
  </div>
</section>
