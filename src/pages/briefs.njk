---
layout: base.njk
navActive: insights
pageTitle: Weekly Intelligence Briefs
permalink: /insights/briefs/index.html
extraCss: |
  .briefs-list { display: grid; gap: 20px; margin-top: 32px; }
  .brief-card {
    display: block;
    background: #FFFFFF;
    border: 1px solid #D4C5A9;
    border-radius: 10px;
    padding: 24px 26px;
    text-decoration: none;
    transition: border-color .18s ease, box-shadow .18s ease, transform .18s ease;
  }
  .brief-card:hover {
    border-color: #C5A059;
    box-shadow: 0 6px 22px rgba(26,28,30,0.08);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .brief-card__title {
    font-size: 19px;
    font-weight: 700;
    color: #1A1C1E;
    margin: 0 0 12px;
    line-height: 1.35;
  }
  .brief-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    align-items: center;
    font-size: 13px;
    color: #5E6268;
  }
  .brief-card__count {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #F5F0E8;
    border: 1px solid #D4C5A9;
    color: #1A1C1E;
    font-weight: 600;
    border-radius: 999px;
    padding: 3px 12px;
  }
  .brief-card__cta { margin-top: 16px; font-size: 14px; font-weight: 600; color: #C5A059; }
  .briefs-empty { color: #5E6268; font-size: 15px; margin-top: 16px; }
---
{% set t = i18n["en"] %}

<section class="circuit-bg--subtle page-hero" aria-labelledby="page-title">
  <div class="container">
    <div class="hero-inner" style="min-height:unset;padding:40px 0 32px;">
      <span class="eyebrow">Insights</span>
      <h1 class="hero-title" id="page-title" style="font-size:clamp(28px,4.5vw,48px);">Weekly Intelligence Briefs</h1>
      <p class="hero-sub" style="font-size:17px;">Our regular intelligence briefs on the African sports technology ecosystem — published weekly.</p>
    </div>
  </div>
</section>

<section class="section section--white" aria-labelledby="briefs-heading">
  <div class="container">
    <span class="eyebrow">Briefings</span>
    <h2 class="section-title" id="briefs-heading">All briefs</h2>
    <div class="section-divider"></div>

    {% if briefs.length > 0 %}
      <div class="briefs-list">
        {% for brief in briefs %}
          <a class="brief-card" href="/insights/briefs/{{ brief.date }}/">
            <h3 class="brief-card__title">{{ brief.title }}</h3>
            <div class="brief-card__meta">
              <span class="brief-card__count">{{ brief.itemCount }} item{% if brief.itemCount != 1 %}s{% endif %}</span>
              <span>Published {{ brief.publishedHuman }}</span>
            </div>
            <div class="brief-card__cta">Read the brief →</div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <p class="briefs-empty">No briefs have been published yet. Please check back soon.</p>
    {% endif %}
  </div>
</section>
