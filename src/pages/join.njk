---
layout: base.njk
navActive: join
pagination:
  data: languages.list
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}/join/index.html{% else %}/{{ lang }}/join/index.html{% endif %}"
---
{% set t = i18n[lang] %}
{% set langPrefix = "" if lang == "en" else "/" + lang %}

{# ── HUBSPOT FORM IDS PER LANGUAGE ──
   Replace each entry with the language-specific form ID once you build the
   translated form in HubSpot. Languages still pointing at the English form
   ID will continue to show the "Please complete this form in English" notice.
   Update shareUrl too so the "Form not loading? Open directly" link is right. #}
{% set ENGLISH_FORM_ID = "89c776d4-6193-4ddf-8b57-42728771345b" %}
{% set ENGLISH_SHARE_URL = "https://2gc5va.share-eu1.hsforms.com/2icd21GGTTd-LV0Jyh3E0Ww" %}

{% set formConfig = {
  "en": { "formId": "89c776d4-6193-4ddf-8b57-42728771345b", "shareUrl": ENGLISH_SHARE_URL },
  "fr": { "formId": "3224bae7-ea03-4b45-9aaa-a880a6e3cc95", "shareUrl": ENGLISH_SHARE_URL },
  "pt": { "formId": "6c546808-d2c6-4291-b3f6-d37b043b1c8d", "shareUrl": ENGLISH_SHARE_URL },
  "ar": { "formId": "4e0882a3-3f73-420b-bb30-6ed8edc2406e", "shareUrl": ENGLISH_SHARE_URL },
  "sw": { "formId": "59d69267-a182-4795-9623-fad103253d88", "shareUrl": ENGLISH_SHARE_URL }
} %}

{% set currentForm = formConfig[lang] %}
{% set hasNativeForm = lang == "en" or currentForm.formId != ENGLISH_FORM_ID %}

<section class="circuit-bg page-hero" aria-labelledby="page-title">
  <div class="container">
    <div class="hero-inner" style="min-height:unset;padding:40px 0 32px;">
      <span class="eyebrow">{{ t.join.hero_eyebrow }}</span>
      <h1 class="hero-title" id="page-title" style="font-size:clamp(28px,4.5vw,48px);">{{ t.join.hero_heading }}</h1>
      <p class="hero-sub" style="font-size:17px;">{{ t.join.hero_subheading }}</p>
    </div>
  </div>
</section>

<!-- Early community -->
<section class="section section--dark" aria-labelledby="community-title">
  <div class="container">
    <div class="text-visual reveal">
      <div>
        <span class="eyebrow">{{ t.join.community_eyebrow }}</span>
        <h2 class="section-title section-title--white" id="community-title">{{ t.join.community_heading }}</h2>
        <div class="section-divider"></div>
        <p style="font-size:15px;color:var(--text-dim-dark);line-height:1.85;margin-bottom:16px;">{{ t.join.community_para1 }}</p>
        <p style="font-size:15px;color:var(--text-dim-dark);line-height:1.85;">{{ t.join.community_para2 }}</p>
      </div>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div style="padding:20px 24px;background:rgba(197,160,89,0.07);border-radius:8px;border-left:3px solid var(--gold);">
          <div style="font-size:12px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.07em;margin-bottom:8px;">{{ t.join.what_membership_means }}</div>
          <ul style="list-style:none;padding:0;margin:0;">
            <li style="font-size:14px;color:rgba(255,255,255,0.65);padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;gap:8px;align-items:flex-start;"><span class="arrow-bullet" style="color:var(--gold);flex-shrink:0;">→</span> {{ t.join.benefit1 }}</li>
            <li style="font-size:14px;color:rgba(255,255,255,0.65);padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;gap:8px;align-items:flex-start;"><span class="arrow-bullet" style="color:var(--gold);flex-shrink:0;">→</span> {{ t.join.benefit2 }}</li>
            <li style="font-size:14px;color:rgba(255,255,255,0.65);padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;gap:8px;align-items:flex-start;"><span class="arrow-bullet" style="color:var(--gold);flex-shrink:0;">→</span> {{ t.join.benefit3 }}</li>
            <li style="font-size:14px;color:rgba(255,255,255,0.65);padding:5px 0;display:flex;gap:8px;align-items:flex-start;"><span class="arrow-bullet" style="color:var(--gold);flex-shrink:0;">→</span> {{ t.join.benefit4 }}</li>
          </ul>
        </div>
        <p style="font-size:13px;color:rgba(255,255,255,0.35);font-style:italic;padding:0 4px;">{{ t.join.thoughtful_note }}</p>
      </div>
    </div>
  </div>
</section>

<!-- Who it's for -->
<section class="section section--white" aria-labelledby="for-whom-title">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="eyebrow">{{ t.join.for_whom_eyebrow }}</span>
      <h2 class="section-title" id="for-whom-title">{{ t.join.for_whom_heading }}</h2>
      <div class="section-divider section-divider--center"></div>
    </div>
    <div class="grid-3 reveal">
      <div class="card card--gold-top">
        <h3>{{ t.join.audience1_title }}</h3>
        <p>{{ t.join.audience1_body }}</p>
      </div>
      <div class="card card--gold-top">
        <h3>{{ t.join.audience2_title }}</h3>
        <p>{{ t.join.audience2_body }}</p>
      </div>
      <div class="card card--gold-top">
        <h3>{{ t.join.audience3_title }}</h3>
        <p>{{ t.join.audience3_body }}</p>
      </div>
    </div>
  </div>
</section>

<!-- Form -->
<section class="section section--warm section--always-light" aria-labelledby="form-title">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="eyebrow">{{ t.join.form_eyebrow }}</span>
      <h2 class="section-title" id="form-title">{{ t.join.form_heading }}</h2>
      <div class="section-divider section-divider--center"></div>
      <p class="section-lead" style="margin:0 auto 40px;">{{ t.join.form_lead }}</p>
    </div>

    {# Show the "complete in English" notice only when this language is still
       using the English form (i.e., a translated form hasn't been built yet) #}
    {% if not hasNativeForm and t.join.english_form_notice %}
    <div class="form-language-notice reveal" role="note">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      <p>{{ t.join.english_form_notice }}</p>
    </div>
    {% endif %}

    <!-- HUBSPOT FORM (v2 inline embed — renders as real DOM so our CSS overrides apply) -->
    <div class="reveal" style="min-height:520px;max-width:680px;margin:0 auto;">
      <div id="hubspot-join-form"></div>
      <script charset="utf-8" type="text/javascript" src="https://js-eu1.hsforms.net/forms/embed/v2.js"></script>
      <script>
        (function(){
          // The form section is locked to light/cream styling regardless of
          // site theme (see .section--always-light in style.css), so the form
          // labels always need to be dark. We force this via inline JS after
          // mount because HubSpot ships !important inline styles that beat
          // external CSS.

          function lockFormColours(formEl) {
            if (!formEl || !formEl.querySelectorAll) return;
            var DARK_TEXT = '#0F1113';
            var GOLD = '#C5A059';

            var textNodes = formEl.querySelectorAll(
              'label, label *, legend, legend *, .hs-field-desc, ' +
              '.hs-richtext, .hs-richtext *, ' +
              '.hs-form-booleancheckbox-display, .hs-form-booleancheckbox-display *, ' +
              '.legal-consent-container, .legal-consent-container *'
            );
            for (var i = 0; i < textNodes.length; i++) {
              textNodes[i].style.setProperty('color', DARK_TEXT, 'important');
            }

            // Required asterisks always gold
            var asterisks = formEl.querySelectorAll('.hs-form-required');
            for (var j = 0; j < asterisks.length; j++) {
              asterisks[j].style.setProperty('color', GOLD, 'important');
            }
          }

          function getFormEl(handle) {
            return handle && handle[0] ? handle[0] : handle;
          }

          function setupForm() {
            if (!window.hbspt) return false;
            hbspt.forms.create({
              region: "eu1",
              portalId: "148373686",
              formId: "{{ currentForm.formId }}",
              target: "#hubspot-join-form",
              onFormReady: function($form) {
                lockFormColours(getFormEl($form));
              }
            });
            return true;
          }

          if (!setupForm()) {
            window.addEventListener("load", setupForm);
          }
        })();
      </script>
    </div>
    <p style="text-align:center;font-size:13px;color:var(--text-muted);margin-top:16px;">
      {{ t.join.form_fallback }}
      <a href="{{ currentForm.shareUrl }}" target="_blank" rel="noopener noreferrer">{{ t.join.form_open_directly }}</a>
    </p>
  </div>
</section>

