---
layout: base.njk
navActive: join
pagination:
  data: languages.list
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}/join/index.html{% else %}/{{ lang }}/join/index.html{% endif %}"
---
{% set t = i18n[lang] %}
{% set langPrefix = "" if lang == "en" else "/" + lang %}

<section class="circuit-bg page-hero" aria-labelledby="page-title">
  <div class="container">
    <div class="hero-inner" style="min-height:unset;padding:40px 0 32px;">
      <span class="eyebrow">{{ t.join.hero_eyebrow }}</span>
      <h1 class="hero-title" id="page-title" style="font-size:clamp(28px,4.5vw,48px);">{{ t.join.hero_heading }}</h1>
      <p class="hero-sub" style="font-size:17px;">{{ t.join.hero_subheading }}</p>
    </div>
  </div>
</section>

<!-- Early community -->
<section class="section section--dark" aria-labelledby="community-title">
  <div class="container">
    <div class="text-visual reveal">
      <div>
        <span class="eyebrow">{{ t.join.community_eyebrow }}</span>
        <h2 class="section-title section-title--white" id="community-title">{{ t.join.community_heading }}</h2>
        <div class="section-divider"></div>
        <p style="font-size:15px;color:var(--text-dim-dark);line-height:1.85;margin-bottom:16px;">{{ t.join.community_para1 }}</p>
        <p style="font-size:15px;color:var(--text-dim-dark);line-height:1.85;">{{ t.join.community_para2 }}</p>
      </div>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div style="padding:20px 24px;background:rgba(197,160,89,0.07);border-radius:8px;border-left:3px solid var(--gold);">
          <div style="font-size:12px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.07em;margin-bottom:8px;">{{ t.join.what_membership_means }}</div>
          <ul style="list-style:none;padding:0;margin:0;">
            <li style="font-size:14px;color:rgba(255,255,255,0.65);padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">→</span> {{ t.join.benefit1 }}</li>
            <li style="font-size:14px;color:rgba(255,255,255,0.65);padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">→</span> {{ t.join.benefit2 }}</li>
            <li style="font-size:14px;color:rgba(255,255,255,0.65);padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">→</span> {{ t.join.benefit3 }}</li>
            <li style="font-size:14px;color:rgba(255,255,255,0.65);padding:5px 0;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--gold);flex-shrink:0;">→</span> {{ t.join.benefit4 }}</li>
          </ul>
        </div>
        <p style="font-size:13px;color:rgba(255,255,255,0.35);font-style:italic;padding:0 4px;">{{ t.join.thoughtful_note }}</p>
      </div>
    </div>
  </div>
</section>

<!-- Who it's for -->
<section class="section section--white" aria-labelledby="for-whom-title">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="eyebrow">{{ t.join.for_whom_eyebrow }}</span>
      <h2 class="section-title" id="for-whom-title">{{ t.join.for_whom_heading }}</h2>
      <div class="section-divider section-divider--center"></div>
    </div>
    <div class="grid-3 reveal">
      <div class="card card--gold-top">
        <h3>{{ t.join.audience1_title }}</h3>
        <p>{{ t.join.audience1_body }}</p>
      </div>
      <div class="card card--gold-top">
        <h3>{{ t.join.audience2_title }}</h3>
        <p>{{ t.join.audience2_body }}</p>
      </div>
      <div class="card card--gold-top">
        <h3>{{ t.join.audience3_title }}</h3>
        <p>{{ t.join.audience3_body }}</p>
      </div>
    </div>
  </div>
</section>

<!-- Form -->
<section class="section section--warm" aria-labelledby="form-title">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="eyebrow">{{ t.join.form_eyebrow }}</span>
      <h2 class="section-title" id="form-title">{{ t.join.form_heading }}</h2>
      <div class="section-divider section-divider--center"></div>
      <p class="section-lead" style="margin:0 auto 40px;">{{ t.join.form_lead }}</p>
    </div>

    {% if lang != "en" and t.join.english_form_notice %}
    <div class="form-language-notice reveal" role="note">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      <p>{{ t.join.english_form_notice }}</p>
    </div>
    {% endif %}

    <!-- TALLY FORM -->
    <div class="form-wrap reveal">
      <iframe
        id="tally-iframe"
        data-tally-src="https://tally.so/embed/BzagEQ?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1&theme=dark"
        width="100%"
        height="520"
        frameborder="0"
        marginheight="0"
        marginwidth="0"
        title="{{ t.join.form_iframe_title }}"
        style="min-height:520px;"
      ></iframe>
    </div>
    <p style="text-align:center;font-size:13px;color:var(--text-muted);margin-top:16px;">
      {{ t.join.form_fallback }}
      <a href="https://tally.so/r/BzagEQ" target="_blank" rel="noopener noreferrer">{{ t.join.form_open_directly }}</a>
    </p>
    <script>
      (function(){
        var TALLY_URL = "https://tally.so/widgets/embed.js";
        var iframe = document.getElementById("tally-iframe");
        var baseSrc = "https://tally.so/embed/BzagEQ?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1&theme=dark";
        // Fallback: if the Tally widget script fails to load within 4 seconds,
        // load the form directly via src attribute
        var fallbackTimer = setTimeout(function(){
          if(iframe && !iframe.src){
            iframe.src = baseSrc;
          }
        }, 4000);
        if(typeof Tally !== "undefined"){
          clearTimeout(fallbackTimer);
          Tally.loadEmbeds();
        } else {
          var s = document.createElement("script");
          s.src = TALLY_URL;
          s.onload = function(){
            clearTimeout(fallbackTimer);
            if(window.Tally) Tally.loadEmbeds();
          };
          s.onerror = function(){
            // Script blocked or failed — load directly
            clearTimeout(fallbackTimer);
            if(iframe){
              iframe.src = baseSrc;
            }
          };
          document.body.appendChild(s);
        }
      })();
    </script>
  </div>
</section>

<!-- What happens next -->
<section class="section section--white" aria-labelledby="next-title">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">{{ t.join.next_eyebrow }}</span>
      <h2 class="section-title" id="next-title">{{ t.join.next_heading }}</h2>
      <div class="section-divider"></div>
    </div>
    <div class="grid-3 reveal">
      <div class="card card--gold-top">
        <h3 style="font-size:15px;">{{ t.join.next1_title }}</h3>
        <p>{{ t.join.next1_body }}</p>
      </div>
      <div class="card card--gold-top">
        <h3 style="font-size:15px;">{{ t.join.next2_title }}</h3>
        <p>{{ t.join.next2_body }}</p>
      </div>
      <div class="card card--gold-top">
        <h3 style="font-size:15px;">{{ t.join.next3_title }}</h3>
        <p>{{ t.join.next3_body }}</p>
      </div>
    </div>
  </div>
</section>