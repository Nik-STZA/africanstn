---
layout: base.njk
navActive: ecosystem
pagination:
  data: languages.list
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}/ecosystem/index.html{% else %}/{{ lang }}/ecosystem/index.html{% endif %}"
---
{% set t = i18n[lang] %}
{% set langPrefix = "" if lang == "en" else "/" + lang %}

<section class="circuit-bg--subtle page-hero" aria-labelledby="page-title">
  <div class="container">
    <div class="hero-inner" style="min-height:unset;padding:40px 0 32px;">
      <span class="eyebrow">{{ t.ecosystem.hero_eyebrow }}</span>
      <h1 class="hero-title" id="page-title" style="font-size:clamp(28px,4.5vw,48px);">{{ t.ecosystem.hero_heading }}</h1>
      <p class="hero-sub" style="font-size:17px;">{{ t.ecosystem.hero_subheading }}</p>
    </div>
  </div>
</section>

<!-- Directory status -->
<section class="section section--white" aria-labelledby="directory-title">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">{{ t.ecosystem.directory_eyebrow }}</span>
      <h2 class="section-title" id="directory-title">{{ t.ecosystem.directory_heading }}</h2>
      <div class="section-divider"></div>
      <p class="section-lead">{{ t.ecosystem.directory_lead }}</p>
    </div>
    <div class="grid-3" style="align-items:stretch;">
      <div class="card card--gold-top reveal" style="display:flex;flex-direction:column;">
        <h3>{{ t.ecosystem.card1_title }}</h3>
        <p>{{ t.ecosystem.card1_body }}</p>
        <a href="{{ langPrefix }}/join/" class="card-link" style="margin-top:auto;">{{ t.ecosystem.register_interest }}</a>
      </div>
      <div class="card card--gold-top reveal" style="display:flex;flex-direction:column;">
        <h3>{{ t.ecosystem.card2_title }}</h3>
        <p>{{ t.ecosystem.card2_body }}</p>
        <a href="{{ langPrefix }}/join/" class="card-link" style="margin-top:auto;">{{ t.ecosystem.register_interest }}</a>
      </div>
      <div class="card card--gold-top reveal" style="display:flex;flex-direction:column;">
        <h3>{{ t.ecosystem.card3_title }}</h3>
        <p>{{ t.ecosystem.card3_body }}</p>
        <a href="{{ langPrefix }}/what-is-sports-tech/" class="card-link" style="margin-top:auto;">{{ t.ecosystem.see_full_map }}</a>
      </div>
    </div>
  </div>
</section>

<!-- Primary market: SA -->
<section class="section section--warm" aria-labelledby="market-title">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">{{ t.ecosystem.market_eyebrow }}</span>
      <h2 class="section-title" id="market-title">{{ t.ecosystem.market_heading }}</h2>
      <div class="section-divider"></div>
    </div>
    <div class="text-visual reveal">
      <div>
        <p style="font-size:15px;color:var(--text-secondary);line-height:1.8;margin-bottom:16px;">{{ t.ecosystem.market_para1 }}</p>
        <p style="font-size:15px;color:var(--text-secondary);line-height:1.8;margin-bottom:16px;">{{ t.ecosystem.market_para2 }}</p>
        <p style="font-size:15px;color:var(--text-secondary);line-height:1.8;">{{ t.ecosystem.market_para3 }}</p>
      </div>
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="card card--gold-top" style="padding:20px;">
          <h3 style="font-size:15px;">{{ t.ecosystem.market_card1_title }}</h3>
          <p>{{ t.ecosystem.market_card1_body }}</p>
        </div>
        <div class="card card--gold-top" style="padding:20px;">
          <h3 style="font-size:15px;">{{ t.ecosystem.market_card2_title }}</h3>
          <p>{{ t.ecosystem.market_card2_body }}</p>
        </div>
        <div class="card card--gold-top" style="padding:20px;">
          <h3 style="font-size:15px;">{{ t.ecosystem.market_card3_title }}</h3>
          <p>{{ t.ecosystem.market_card3_body }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Tech domains -->
<section class="section section--dark" aria-labelledby="domains-title">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="eyebrow">{{ t.ecosystem.domains_eyebrow }}</span>
      <h2 class="section-title section-title--white" id="domains-title">{{ t.ecosystem.domains_heading }}</h2>
      <div class="section-divider section-divider--center"></div>
      <p class="section-lead section-lead--dark" style="margin:0 auto 40px;">{{ t.ecosystem.domains_lead }} <a href="{{ langPrefix }}/what-is-sports-tech/" style="color:var(--gold);">{{ t.ecosystem.domains_link }}</a></p>
    </div>
    <div class="grid-2 reveal" style="gap:16px;">
      <div class="zone zone--gold" style="border-radius:8px;padding:24px;">
        <div class="zone-title">{{ t.ecosystem.domain1_title }}</div>
        <p style="font-size:13px;color:rgba(255,255,255,0.55);margin-bottom:10px;">{{ t.ecosystem.domain1_body }}</p>
      </div>
      <div class="zone zone--green" style="border-radius:8px;padding:24px;">
        <div class="zone-title">{{ t.ecosystem.domain2_title }}</div>
        <p style="font-size:13px;color:rgba(255,255,255,0.55);margin-bottom:10px;">{{ t.ecosystem.domain2_body }}</p>
      </div>
      <div class="zone zone--grey" style="border-radius:8px;padding:24px;">
        <div class="zone-title">{{ t.ecosystem.domain3_title }}</div>
        <p style="font-size:13px;color:rgba(255,255,255,0.55);margin-bottom:10px;">{{ t.ecosystem.domain3_body }}</p>
      </div>
      <div class="zone zone--amber" style="border-radius:8px;padding:24px;">
        <div class="zone-title">{{ t.ecosystem.domain4_title }}</div>
        <p style="font-size:13px;color:rgba(255,255,255,0.55);margin-bottom:10px;">{{ t.ecosystem.domain4_body }}</p>
      </div>
    </div>
  </div>
</section>

<section class="section circuit-bg section--circuit">
  <div class="container" style="text-align:center;">
    <div class="reveal">
      <span class="eyebrow">{{ t.ecosystem.cta_eyebrow }}</span>
      <h2 class="section-title section-title--white" style="max-width:560px;margin:0 auto 16px;">{{ t.ecosystem.cta_heading }}</h2>
      <p class="section-lead section-lead--dark" style="margin:0 auto 36px;max-width:520px;">{{ t.ecosystem.cta_body }}</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <a href="{{ langPrefix }}/join/" class="btn btn-primary">{{ t.ecosystem.register_company_btn }}</a>
        <a href="{{ langPrefix }}/what-is-sports-tech/" class="btn btn-outline">{{ t.ecosystem.explore_sector_btn }}</a>
      </div>
    </div>
  </div>
</section>
